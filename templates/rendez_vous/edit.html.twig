{% extends 'base.html.twig' %}

{% block title %}Modifier le rendez-vous - Barber Studio{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Modifier le rendez-vous</h1>
    <p class="mb-0" style="color: #ccc;">Mettez à jour les informations du rendez-vous</p>
</div>

<div class="styled-card">
    {{ include('rendez_vous/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
</div>

<div class="mt-4">
    <a href="{{ path('app_rendez_vous_index') }}" class="link-primary">← Retour à la liste</a>
</div>

<div class="mt-4">
    {{ include('rendez_vous/_delete_form.html.twig') }}
</div>
{% endblock %}

