{% extends 'base.html.twig' %}

{% block title %}Rendez-vous - Barber Studio{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Détails du rendez-vous</h1>
        <p class="mb-0" style="color: #ccc;">Informations complètes</p>
    </div>

    <div class="styled-card mb-4">
        <div class="card-header styled-card-header">
            Rendez-vous #{{ rendez_vou.id }}
        </div>
        <div class="card-body">
            <table class="table mb-0">
                <tbody>
                    <tr>
                        <th style="width: 200px;">Date et heure</th>
                        <td>{{ rendez_vou.DateHeure ? rendez_vou.DateHeure|date('d/m/Y H:i') : '' }}</td>
                    </tr>
                    <tr>
                        <th>Prestation</th>
                        <td>
                            <strong>{{ rendez_vou.prestation.nom }}</strong>
                            <br><small class="text-muted">{{ rendez_vou.prestation.duree }} min - {{ rendez_vou.prestation.prix }}€</small>
                        </td>
                    </tr>
                    <tr>
                        <th>Statut</th>
                        <td>
                            {% if rendez_vou.Statut == 'en attente' %}
                                <span class="badge bg-warning">En attente</span>
                            {% elseif rendez_vou.Statut == 'accepté' %}
                                <span class="badge bg-success">Accepté</span>
                            {% elseif rendez_vou.Statut == 'terminé' %}
                                <span class="badge bg-info">Terminé</span>
                            {% elseif rendez_vou.Statut == 'annulé' %}
                                <span class="badge bg-danger">Annulé</span>
                            {% else %}
                                {{ rendez_vou.Statut }}
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>Commentaire</th>
                        <td>{{ rendez_vou.Commentaire ?: 'Aucun commentaire' }}</td>
                    </tr>
                    {% if is_granted('ROLE_ADMIN') %}
                    <tr>
                        <th>Client</th>
                        <td>
                            {{ rendez_vou.user.Prenom }} {{ rendez_vou.user.Nom }}
                            <br><small class="text-muted">{{ rendez_vou.user.email }}</small>
                        </td>
                    </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    {# Formulaire de changement de statut pour l'admin #}
    {% if is_granted('ROLE_ADMIN') %}
        <div class="styled-card mb-4">
            <div class="card-header styled-card-header">
                Modifier le statut
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('app_rendez_vous_statut', {'id': rendez_vou.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ rendez_vou.id) }}">
                    <div class="row align-items-end">
                        <div class="col-md-4">
                            <label for="statut" class="form-label">Nouveau statut</label>
                            <select name="statut" id="statut" class="form-select">
                                <option value="en attente" {% if rendez_vou.Statut == 'en attente' %}selected{% endif %}>En attente</option>
                                <option value="accepté" {% if rendez_vou.Statut == 'accepté' %}selected{% endif %}>Accepté</option>
                                <option value="terminé" {% if rendez_vou.Statut == 'terminé' %}selected{% endif %}>Terminé</option>
                                <option value="annulé" {% if rendez_vou.Statut == 'annulé' %}selected{% endif %}>Annulé</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn bouton-rouge">Mettre à jour</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    {% endif %}

    <div class="d-flex gap-2 mb-4">
        <a href="{{ path('app_rendez_vous_index') }}" class="btn bouton-clair">
            ← Retour à la liste
        </a>
        
        {% if is_granted('ROLE_ADMIN') or rendez_vou.user == app.user %}
            <a href="{{ path('app_rendez_vous_edit', {'id': rendez_vou.id}) }}" class="btn bouton-noir">
                Modifier
            </a>
        {% endif %}
    </div>

    {% if is_granted('ROLE_ADMIN') or rendez_vou.user == app.user %}
        {{ include('rendez_vous/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}

