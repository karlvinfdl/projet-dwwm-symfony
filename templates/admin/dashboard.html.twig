{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin - Barber Studio{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="page-header">
        <h1>Dashboard Admin</h1>
        <p class="mb-0" style="color: #ccc;">Gestion du salon de coiffure</p>
    </div>

    {# Statistiques #}
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card stat-card stat-card-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Rendez-vous</h5>
                    <p class="card-text display-4">{{ totalRendezVous }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card stat-card-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">En Attente</h5>
                    <p class="card-text display-4">{{ rendezVousEnAttente }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card stat-card-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Prestations</h5>
                    <p class="card-text display-4">{{ totalPrestations }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card stat-card-info mb-3">
                <div class="card-body">
                    <h5 class="card-title">Utilisateurs</h5>
                    <p class="card-text display-4">{{ totalUtilisateurs }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Derniers rendez-vous #}
    <div class="card mb-4">
        <div class="card-header">
            Derniers Rendez-vous
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Client</th>
                        <th>Prestation</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for rendezVous in derniersRendezVous %}
                    <tr>
                        <td>{{ rendezVous.DateHeure|date('d/m/Y H:i') }}</td>
                        <td>{{ rendezVous.user.Prenom }} {{ rendezVous.user.Nom }}</td>
                        <td>{{ rendezVous.prestation.Nom }}</td>
                        <td>
                            {% if rendezVous.Statut == 'en attente' %}
                                <span class="badge bg-warning">En attente</span>
                            {% elseif rendezVous.Statut == 'accepté' %}
                                <span class="badge bg-success">Accepté</span>
                            {% elseif rendezVous.Statut == 'terminé' %}
                                <span class="badge bg-info">Terminé</span>
                            {% elseif rendezVous.Statut == 'annulé' %}
                                <span class="badge bg-danger">Annulé</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ rendezVous.Statut }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_rendez_vous_show', {'id': rendezVous.id}) }}" class="btn btn-action btn-action-view">Voir</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-4">Aucun rendez-vous trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a href="{{ path('app_rendez_vous_index') }}" class="btn bouton-noir">
            Voir tous les rendez-vous
        </a>
        <a href="{{ path('app_prestation_index') }}" class="btn bouton-noir">
            Voir les prestations
        </a>
        <a href="{{ path('app_home') }}" class="btn bouton-clair">
            Retour à l'accueil
        </a>
    </div>
</div>
{% endblock %}

