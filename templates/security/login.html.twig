{% extends 'base.html.twig' %}

{% block title %}Connexion - Barber Studio{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>BARBER STUDIO</h1>
            <p class="mb-0 mt-2" style="color: #ccc;">Connexion</p>
        </div>
        <div class="auth-body">
            {% if error %}
                <div class="alert alert-danger">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="alert alert-info">
                    Vous êtes connecté en tant que {{ app.user.userIdentifier }}, 
                    <a href="{{ logout_path() }}" class="alert-link">Déconnexion</a>
                </div>
            {% endif %}

            <form method="post">
                <div class="mb-3">
                    <label for="inputEmail" class="form-label">Email</label>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" 
                           class="form-control" autocomplete="email" required autofocus 
                           placeholder="Votre adresse email">
                </div>
                <div class="mb-3">
                    <label for="inputPassword" class="form-label">Mot de passe</label>
                    <input type="password" name="password" id="inputPassword" 
                           class="form-control" autocomplete="current-password" required
                           placeholder="Votre mot de passe">
                </div>
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" 
                       value="{{ csrf_token('authenticate') }}">

                <div class="mb-3 form-check">
                    <input type="checkbox" name="_remember_me" id="_remember_me" class="form-check-input">
                    <label for="_remember_me" class="form-check-label">Se souvenir de moi</label>
                </div>

                <button class="btn bouton-rouge w-100 py-2" type="submit">
                    Se connecter
                </button>
            </form>

            <hr class="my-4">

            <p class="text-center mb-0">
                Pas encore de compte ? 
                <a href="{{ path('app_register') }}" class="link-primary">Créer un compte</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}

