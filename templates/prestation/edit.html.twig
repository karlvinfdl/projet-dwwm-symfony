{% extends 'base.html.twig' %}

{% block title %}Modifier la prestation - Barber Studio{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Modifier la prestation</h1>
    <p class="mb-0" style="color: #ccc;">Mettez à jour les informations de la prestation</p>
</div>

<div class="styled-card">
    {{ include('prestation/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
</div>

<div class="mt-4">
    <a href="{{ path('app_prestation_index') }}" class="link-primary">← Retour à la liste</a>
</div>

<div class="mt-4">
    {{ include('prestation/_delete_form.html.twig') }}
</div>
{% endblock %}

